{% extends 'base.html.twig' %}

{% block title %}Commandes | {{parent()}}{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>
<div class="example-wrapper">
    <h1 class="text-3xl mb-7">Commandes</h1>
    {% for message in app.flashes('notice') %}
        <div id="alert-3" class="flex sm:items-center p-4 mb-4 text-sm rounded bg-green-200" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5 md:mt-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            <span class="sr-only">Info</span>
            <div class="ms-2 text-sm ">
                {{ message }}
            </div>
            <button type="button" class="ms-auto -mx-1.5 -my-1.5 rounded focus:ring-2 focus:ring-success-medium p-1.5 hover:bg-success-medium inline-flex items-center justify-center h-8 w-8 shrink-0 shrink-0" data-dismiss-target="#alert-3" aria-label="Close">
                <span class="sr-only">Close</span>
                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/></svg>
            </button>
        </div>
    {% endfor %}
    <div class="border border-gray-200 rounded-xl relative">
        <a class="absolute top-5 right-5 text-white bg-blue-500 box-border border border-transparent hover:bg-blue-700 focus:ring-4 focus:ring-brand-medium shadow-xs font-medium transition rounded-md text-sm px-3 py-2 focus:outline-none" href={{ path('app_commandes_new') }}>
            Nouvelle commande
        </a>
        <table class="w-full text-sm text-left rtl:text-right text-body">
            <div class="flex justify-between w-full">
                <caption class="p-5 text-lg font-medium text-left rtl:text-right text-heading">
                    Vos commandes
                    <p class="mt-1.5 text-sm font-normal text-body text-gray-500">Description du card</p>
                </caption>
            </div>
            <thead class="text-sm text-gray-600 bg-gray-100 border-b-gray-900 border-t border-default-medium">
            <tr>
                <th scope="col" class="px-6 py-3 font-medium">
                    ID
                </th>
                <th scope="col" class="px-6 py-3 font-medium">
                    Titre
                </th>
                <th scope="col" class="px-6 py-3 font-medium">
                    Crée par
                </th>
                <th scope="col" class="px-6 py-3 font-medium">
                    Date
                </th>
                <th scope="col" class="px-6 py-3 font-medium">
                    <span class="sr-only">Edit</span>
                </th>
            </tr>
            </thead>
            <tbody>
            {% for commande in userCommandes %}
                <tr class="bg-neutral-primary-soft border-b-gray-900">
                    <th scope="row" class="px-6 py-4 font-medium text-heading whitespace-nowrap">
                        {{ commande.id }}
                    </th>
                    <td class="px-6 py-4">
                        {{ commande.title }}
                    </td>
                    <td class="px-6 py-4">
                        {{ commande.createdBy.email }}
                    </td>
                    <td class="px-6 py-4">
                        {{ commande.createdAt|date('d M Y H:i') }}
                    </td>
                    <td class="py-4 text-right flex gap-2">
                        <a href="#" class="text-blue-700 font-medium hover:underline">Modifier</a>
                        <form method="post" action="{{ path('app_commandes_delete', { id: commande.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">
                            <button class="text-red-700 font-medium hover:underline" onclick="return confirm('Are you sure?')">
                                Annuler
                            </button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
